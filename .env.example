# RupeeRadar Configuration Settings

# Groq LLM API Key (required for Phase 2 categorization & Phase 3 insight rewriting)
GROQ_API_KEY=your_groq_api_key_here

# Groq LLM Model name to use
GROQ_MODEL=llama-3.3-70b-versatile

# Backend API Database URL (Defaults to local SQLite db file)
DATABASE_URL=sqlite:///./rupeeradar.db

# Frontend API URL configuration (Point to local API port 8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
